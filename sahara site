        <p><a href="#bilyard">Bilyard</a></p>
        <p><a href="#market">Market</a></p>
      </div>
    </div>
    <div class="bottom-bar">
      <span>© 2026 Sahara. Barcha huquqlar himoyalangan.</span>
      <span>Sinov versiyasi — test uchun tayyorlangan</span>
    </div>
  </div>
</footer>

<script>
  // Stars canvas
  const canvas = document.getElementById('stars');
  const ctx = canvas.getContext('2d');
  function resizeCanvas(){
    canvas.width = window.innerWidth;
    canvas.height = document.querySelector('.hero').offsetHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);
  const stars = Array.from({length:120}, ()=>({
    x: Math.random()*canvas.width,
    y: Math.random()*canvas.height*0.8,
    r: Math.random()*1.4+0.3,
    phase: Math.random()*Math.PI*2,
    speed: Math.random()*0.02+0.005
  }));
  function drawStars(t){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    stars.forEach(s=>{
      const alpha = 0.4 + 0.6*Math.sin(t*s.speed + s.phase)*0.5+0.3;
      ctx.beginPath();
      ctx.fillStyle = 'rgba(243,234,214,'+Math.max(0.15,alpha)+')';
      ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
      ctx.fill();
    });
    requestAnimationFrame(drawStars);
  }
  requestAnimationFrame(drawStars);

  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('on'));
      document.querySelectorAll('.menu-panel').forEach(p=>p.classList.remove('on'));
      btn.classList.add('on');
      document.getElementById(btn.dataset.tab).classList.add('on');
    });
  });

  // Route progress + waypoints
  const stops = ['hotel','restoran','oyin','bilyard','market'];
  const routeEl = document.getElementById('route');
  const svg = routeEl.querySelector('svg');
  const fillPath = document.getElementById('routeFill');
  const totalLen = fillPath.getTotalLength();
  fillPath.style.strokeDasharray = totalLen;

  const waypoints = stops.map((id, i)=>{
    const el = document.createElement('div');
    el.className='waypoint';
    el.innerHTML = '<span>'+document.getElementById(id).querySelector('h2, .head-row h2')?.textContent.trim()+'</span>';
    routeEl.appendChild(el);
    return {id, el};
  });

  function updateRoute(){
    const doc = document.documentElement;
    const scrollTop = doc.scrollTop || document.body.scrollTop;
    const scrollHeight = (doc.scrollHeight - doc.clientHeight) || 1;
    const progress = Math.min(1, Math.max(0, scrollTop/scrollHeight));
    fillPath.style.strokeDashoffset = totalLen * (1-progress);

    const routeRect = svg.getBoundingClientRect();
    let activeIndex = -1;
    stops.forEach((id, i)=>{
      const rect = document.getElementById(id).getBoundingClientRect();
      if(rect.top < window.innerHeight*0.6) activeIndex = i;
      const relTop = rect.top + rect.height/2 - routeRect.top;
      const pct = Math.min(1, Math.max(0, relTop/routeRect.height));
      waypoints[i].el.style.top = (pct*routeRect.height) + 'px';
      waypoints[i].el.classList.toggle('active', i===activeIndex);
    });
  }
  window.addEventListener('scroll', updateRoute);
  window.addEventListener('resize', updateRoute);
  updateRoute();
</script>
</body>
</html>
