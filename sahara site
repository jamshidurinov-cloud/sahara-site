<style>
  :root{
    --night:#14121c;
    --night-alt:#1d1a28;
    --panel:#211d2c;
    --gold:#d9a85c;
    --gold-dim:#a9803e;
    --ember:#c1552f;
    --oasis:#6e9277;
    --cream:#f3ead6;
    --muted:#b7afc4;
    --line: rgba(217,168,92,0.25);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--night);
    color:var(--cream);
    font-family:'Manrope',sans-serif;
    overflow-x:hidden;
  }
  h1,h2,h3{
    font-family:'Cormorant',serif;
    font-weight:600;
    letter-spacing:0.01em;
  }
  .mono{font-family:'Space Mono',monospace;}
  .script{
    font-family:'Pacifico',cursive;
    font-weight:400;
    letter-spacing:0;
  }
  a{color:inherit;text-decoration:none;}
  .wrap{max-width:1180px;margin:0 auto;padding:0 32px;}

  @media (prefers-reduced-motion: reduce){
    *{animation:none !important; transition:none !important;}
  }

  /* ---------- NAV ---------- */
  header{
    position:fixed; top:0; left:0; right:0; z-index:100;
    display:flex; align-items:center; justify-content:space-between;
    padding:20px 32px;
    background:linear-gradient(180deg, rgba(20,18,28,0.92), rgba(20,18,28,0));
    backdrop-filter:blur(2px);
  }
  .logo{
    font-family:'Pacifico',cursive; font-size:1.7rem; font-weight:400;
    letter-spacing:0; color:var(--gold);
  }
  nav{display:flex; gap:26px;}
  nav a{
    font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em;
    color:var(--muted); position:relative; padding-bottom:4px;
    transition:color .25s;
  }
  nav a::after{
    content:""; position:absolute; left:0; bottom:0; height:1px; width:0;
    background:var(--gold); transition:width .3s;
  }
  nav a:hover{color:var(--cream);}
  nav a:hover::after{width:100%;}
  .nav-cta{
    border:1px solid var(--gold-dim); padding:8px 16px; border-radius:2px;
    color:var(--gold) !important;
  }
  .nav-cta:hover{background:var(--gold); color:var(--night) !important;}
  .nav-cta::after{display:none;}
  #navToggle{display:none;}

  /* ---------- ROUTE (signature element) ---------- */
  #route{
    position:fixed; left:18px; top:0; bottom:0; width:40px; z-index:90;
    display:flex; align-items:center; pointer-events:none;
  }
  #route svg{height:82vh; width:40px;}
  #route .track{fill:none; stroke:rgba(217,168,92,0.18); stroke-width:2;}
  #route .fill{fill:none; stroke:var(--gold); stroke-width:2; stroke-dasharray:1000; stroke-dashoffset:1000;}
  .waypoint{
    position:absolute; left:11px; width:18px; height:18px; border-radius:50%;
    background:var(--night-alt); border:2px solid var(--gold-dim);
    transform:translateY(-50%);
    display:flex; align-items:center; justify-content:center;
  }
  .waypoint span{
    position:absolute; left:26px; white-space:nowrap; font-size:0.68rem;
    font-family:'Space Mono',monospace; color:var(--muted); letter-spacing:0.05em;
    opacity:0; transform:translateX(-6px); transition:opacity .3s, transform .3s;
  }
  .waypoint.active{border-color:var(--gold); background:var(--gold);}
  .waypoint.active span{opacity:1; transform:translateX(0); color:var(--gold);}
  #camel{
    position:absolute; left:6px; width:28px; height:28px; transform:translate(-5px,-50%);
    transition: top .1s linear;
  }
  @media (max-width: 900px){ #route{display:none;} }

  /* ---------- HERO ---------- */
  .hero{
    position:relative; min-height:100vh; display:flex; flex-direction:column;
    align-items:center; justify-content:center; text-align:center;
    padding:120px 24px 0;
    background:
      linear-gradient(180deg, rgba(20,18,28,0.55) 0%, rgba(20,18,28,0.35) 40%, rgba(20,18,28,0.92) 92%),
      url('images/hero.jpg');
    background-size:cover;
    background-position:center 30%;
    overflow:hidden;
  }
  #stars{position:absolute; inset:0; z-index:0; opacity:0.5;}
  .hero-content{position:relative; z-index:2;}
  .eyebrow{
    font-family:'Space Mono',monospace; font-size:0.75rem; letter-spacing:0.25em;
    text-transform:uppercase; color:var(--gold); margin-bottom:22px; display:inline-block;
  }
  .hero h1{
    font-family:'Pacifico',cursive; font-weight:400;
    font-size:clamp(3.4rem, 11vw, 8rem); line-height:1; color:var(--cream);
    letter-spacing:0.01em;
    text-shadow:0 0 40px rgba(217,168,92,0.35);
  }
  .hero p.tag{
    font-size:1.05rem; color:var(--muted); max-width:520px; margin:26px auto 40px;
    font-weight:400;
  }
  .btn-row{display:flex; gap:16px; justify-content:center; flex-wrap:wrap;}
  .btn{
    padding:14px 30px; font-size:0.85rem; letter-spacing:0.06em; text-transform:uppercase;
    border-radius:2px; transition:all .25s; font-weight:600; cursor:pointer;
  }
  .btn-primary{background:var(--gold); color:var(--night);}
  .btn-primary:hover{background:var(--cream);}
  .btn-ghost{border:1px solid var(--gold-dim); color:var(--gold);}
  .btn-ghost:hover{background:rgba(217,168,92,0.1);}

  .dunes{position:absolute; bottom:-2px; left:0; width:100%; z-index:1;}

  /* ---------- SECTIONS ---------- */
  section.stop{padding:140px 0 100px; position:relative;}
  section.stop:nth-child(even){background:var(--night-alt);}
  .head-row{
    display:flex; justify-content:space-between; align-items:flex-end;
    gap:24px; margin-bottom:56px; flex-wrap:wrap;
    border-bottom:1px solid var(--line); padding-bottom:24px;
  }
  .head-row h2{font-size:clamp(2.2rem,5vw,3.4rem); color:var(--cream);}
  .head-row .stop-no{font-family:'Space Mono',monospace; color:var(--gold-dim); font-size:0.9rem;}
  .lede{color:var(--muted); max-width:640px; font-size:1rem; line-height:1.7; margin-bottom:48px;}

  .grid3{display:grid; grid-template-columns:repeat(3,1fr); gap:24px;}
  .grid2{display:grid; grid-template-columns:repeat(2,1fr); gap:24px;}
  @media (max-width:800px){.grid3,.grid2{grid-template-columns:1fr;}}

  .card{
    background:var(--panel); border:1px solid var(--line); border-radius:3px;
    padding:30px 28px; transition:transform .3s, border-color .3s;
  }
  .card:hover{transform:translateY(-4px); border-color:var(--gold-dim);}
  .card h3{color:var(--gold); font-size:1.5rem; margin-bottom:10px;}
  .card p{color:var(--muted); font-size:0.92rem; line-height:1.6; margin-bottom:18px;}
  .price{
    font-family:'Space Mono',monospace; color:var(--cream); font-size:1.1rem;
    border-top:1px dashed var(--line); padding-top:14px; display:flex; justify-content:space-between;
  }
  .price small{color:var(--muted); font-size:0.7rem;}

  /* menu list */
  .menu-list{list-style:none;}
  .menu-list li{
    display:flex; justify-content:space-between; align-items:baseline;
    padding:16px 0; border-bottom:1px dashed var(--line); gap:16px;
  }
  .menu-list li:first-child{padding-top:0;}
  .menu-list .name{font-size:1.1rem; font-family:'Cormorant',serif; color:var(--cream); font-weight:500;}
  .menu-list .desc{display:block; color:var(--muted); font-size:0.82rem; font-family:'Manrope',sans-serif; margin-top:3px;}
  .menu-list .dots{flex:1; border-bottom:1px dotted var(--line); margin:0 6px; transform:translateY(-6px); min-width:20px;}
  .menu-list .cost{font-family:'Space Mono',monospace; color:var(--gold); white-space:nowrap;}

  .tab-bar{display:flex; gap:8px; margin-bottom:36px; flex-wrap:wrap;}
  .tab-btn{
    padding:9px 18px; font-size:0.8rem; border:1px solid var(--line); border-radius:20px;
    color:var(--muted); cursor:pointer; transition:all .2s; background:transparent;
    font-family:'Manrope',sans-serif;
  }
  .tab-btn.on, .tab-btn:hover{border-color:var(--gold); color:var(--gold);}
  .menu-panel{display:none;}
  .menu-panel.on{display:block;}

  .stat-row{display:flex; gap:40px; flex-wrap:wrap; margin-top:8px;}
  .stat{font-family:'Space Mono',monospace;}
  .stat b{display:block; font-size:2rem; color:var(--gold); font-weight:700;}
  .stat span{color:var(--muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em;}

  .split{display:grid; grid-template-columns:1.1fr 0.9fr; gap:56px; align-items:center;}
  @media (max-width:800px){.split{grid-template-columns:1fr;}}
  .icon-box{width:56px; height:56px; margin-bottom:18px;}

  .market-badges{display:flex; flex-wrap:wrap; gap:12px; margin-top:26px;}
  .badge{
    padding:8px 16px; border:1px solid var(--oasis); color:var(--oasis);
    border-radius:20px; font-size:0.78rem; font-family:'Space Mono',monospace;
  }

  /* contact */
  footer{
    background:var(--night); border-top:1px solid var(--line); padding:70px 0 30px;
  }
  .foot-grid{display:grid; grid-template-columns:1.3fr 1fr 1fr; gap:40px; margin-bottom:50px;}
  @media (max-width:800px){.foot-grid{grid-template-columns:1fr;}}
  footer h4{color:var(--gold); font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:18px; font-family:'Manrope',sans-serif;}
  footer p, footer a{color:var(--muted); font-size:0.92rem; line-height:2;}
  footer a:hover{color:var(--gold);}
  .bottom-bar{
    display:flex; justify-content:space-between; padding-top:26px; border-top:1px solid var(--line);
    font-size:0.75rem; color:var(--muted); flex-wrap:wrap; gap:10px;
  }

  ::selection{background:var(--gold); color:var(--night);}
</style>
</head>
